{
  "name": "tandrezone/order-orchestrator",
  "description": "Order creation package with shipping form template and total calculation.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "tandrezone/ztemp": "^1.0"
  },
  "require-dev": {
    "symfony/polyfill-mbstring": "^1.30",
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Tandrezone\\OrderOrchestrator\\": "src/",
      "Tandrezone\\OrderOrchestrator\\Admin\\": "src/admin/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tandrezone\\OrderOrchestrator\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}

#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Creates (or verifies) the `orders` table in the configured database.
 *
 * Usage:
 *   php bin/create-orders-table [--env=/path/to/.env]
 *
 * Environment variables (or .env file):
 *   DB_HOST     – defaults to 127.0.0.1
 *   DB_PORT     – defaults to 3306
 *   DB_NAME     – defaults to product_management
 *   DB_USER     – defaults to manager
 *   DB_PASS     – defaults to manager
 */

// ── Autoload ─────────────────────────────────────────────────────────────────
$autoloadCandidates = [
    __DIR__ . '/../vendor/autoload.php',   // used as a standalone package
    __DIR__ . '/../../../autoload.php',    // installed via composer into a project
];

$autoloaded = false;
foreach ($autoloadCandidates as $file) {
    if (file_exists($file)) {
        require_once $file;
        $autoloaded = true;
        break;
    }
}

if (!$autoloaded) {
    fwrite(STDERR, "Could not locate autoload.php. Run 'composer install' first.\n");
    exit(1);
}

// ── .env loading (optional) ───────────────────────────────────────────────────
$envArg = null;
foreach ($argv as $arg) {
    if (str_starts_with($arg, '--env=')) {
        $envArg = substr($arg, 6);
    }
}

$envFile = $envArg ?? getcwd() . '/.env';

if (file_exists($envFile)) {
    foreach (file($envFile, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
        $line = trim($line);
        if ($line === '' || str_starts_with($line, '#')) {
            continue;
        }
        [$key, $value] = array_pad(explode('=', $line, 2), 2, '');
        $_ENV[trim($key)] = trim($value, " \t\n\r\0\x0B\"'");
    }
    fwrite(STDOUT, "Loaded environment from: {$envFile}\n");
}

// ── Database connection ───────────────────────────────────────────────────────
$host    = $_ENV['DB_HOST']     ?? '127.0.0.1';
$port    = $_ENV['DB_PORT']     ?? '3306';
$dbName  = $_ENV['DB_NAME']     ?? ($_ENV['DB_DATABASE'] ?? 'product_management');
$user    = $_ENV['DB_USER']     ?? ($_ENV['DB_USERNAME']  ?? 'manager');
$pass    = $_ENV['DB_PASS']     ?? ($_ENV['DB_PASSWORD']  ?? 'manager');
$charset = $_ENV['DB_CHARSET']  ?? 'utf8mb4';

$dsn = sprintf('mysql:host=%s;port=%s;dbname=%s;charset=%s', $host, $port, $dbName, $charset);

try {
    $pdo = new PDO($dsn, $user, $pass, [
        PDO::ATTR_ERRMODE            => PDO::ERRMODE_EXCEPTION,
        PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
        PDO::ATTR_EMULATE_PREPARES   => false,
    ]);
} catch (\PDOException $e) {
    fwrite(STDERR, "Database connection failed: " . $e->getMessage() . "\n");
    exit(1);
}

// ── Run migration ─────────────────────────────────────────────────────────────
use Tandrezone\OrderOrchestrator\OrderRepository;

try {
    (new OrderRepository())->createTable($pdo);
    fwrite(STDOUT, "orders table created (or already exists) in database '{$dbName}'.\n");
} catch (\Throwable $e) {
    fwrite(STDERR, "Migration failed: " . $e->getMessage() . "\n");
    exit(1);
}

exit(0);
